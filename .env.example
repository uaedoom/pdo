# Copy this file to `.env` and fill in your values.
# PDO reads all configuration from environment variables (validated at startup).

# Required: your API key. PDO will refuse to start without it.
# For OpenAI this is your OpenAI key; for OpenRouter use your OpenRouter key.
OPENAI_API_KEY=

# Optional: the model PDO uses. gpt-4.1-mini is only the default.
# On OpenRouter, models are namespaced, e.g. openai/gpt-4.1-mini,
# anthropic/claude-3.5-sonnet, google/gemini-2.0-flash-001, etc.
OPENAI_MODEL=gpt-4.1-mini

# Optional: API endpoint. Leave blank for OpenAI. Set this to use any
# OpenAI-compatible provider. For OpenRouter:
#   OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_BASE_URL=

# Optional: per-provider keys used by the in-app /models picker so you can
# switch between providers at runtime without editing this file each time.
# ANTHROPIC_API_KEY=
# OPENROUTER_API_KEY=

# Optional: override the local Ollama endpoint (default http://localhost:11434/v1).
# Ollama needs no API key. Start it with `ollama serve` and `ollama pull <model>`.
# OLLAMA_BASE_URL=

# Optional UI settings.
# PDO_MARKDOWN=1                 # render replies as Markdown (0 to stream raw text)
# PDO_THEME=cyan                 # cyan | green | magenta | amber | blue | mono

# Optional per-tool permission policy (comma-separated tool names).
# PDO_DENY_TOOLS=run_shell       # block these tools entirely
# PDO_ASK_TOOLS=write_file,git   # require confirmation before these run

# Optional: sampling temperature (0.0 - 2.0). Lower is more deterministic.
TEMPERATURE=0.2

# Optional: where PDO stores its data (memory.json, history.json) and logs.
# Defaults to the installed package directory. Set this to keep state in your
# home directory instead, e.g. PDO_HOME=~/.pdo
# PDO_HOME=
